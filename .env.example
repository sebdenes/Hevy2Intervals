# ─── Hevy → Intervals.icu Sync — Configuration ─────────────────────────────
# Copy this file to .env and fill in your values.

# ── Hevy (requires Hevy Pro) ──
# Get your API key at: https://hevy.com/settings?developer
HEVY_API_KEY=your_hevy_api_key_here
HEVY_BASE_URL=https://api.hevyapp.com

# ── Intervals.icu ──
# Get your API key at: https://intervals.icu/settings (Developer Settings)
# Athlete ID is shown on the same page (or use "0" for self)
INTERVALS_API_KEY=your_intervals_api_key_here
INTERVALS_ATHLETE_ID=0
INTERVALS_BASE_URL=https://intervals.icu

# ── Webhook Security ──
# Shared secret to protect the webhook endpoint.
# Set the same value in Hevy's webhook "Authorization header" as: Bearer <secret>
WEBHOOK_SECRET=change_me_to_a_random_string

# ── Sync Ledger ──
# SQLite database path for tracking synced workouts
SYNC_DB_PATH=hevy_icu_sync.db

# ── Server ──
PORT=8400
LOG_LEVEL=INFO
